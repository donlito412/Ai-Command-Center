{
  "name": "AI Command Center Automation Blueprint",
  "modules": [
    {
      "id": 1,
      "module": "gateway:CustomWebHook",
      "version": 1,
      "parameters": {
        "hook": "command-center-agent-pipeline"
      },
      "mapper": {}
    },
    {
      "id": 2,
      "module": "json:TransformToJSON",
      "version": 1,
      "parameters": {},
      "mapper": {
        "status": "running",
        "workflow": "{{1.workflow}}",
        "engine": "{{1.engine}}",
        "receivedAt": "{{now}}"
      }
    }
  ],
  "metadata": {
    "instant": true,
    "version": 1,
    "scenario": "Command Center agent workflow trigger"
  }
}
